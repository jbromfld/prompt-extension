{
  "name": "smart-copilot-assistant",
  "displayName": "Smart Copilot Assistant",
  "description": "Intelligent prompt suggestions and team collaboration for GitHub Copilot",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Smart Copilot Assistant",
      "properties": {
        "smartCopilot.user.id": {
          "type": "string",
          "default": "",
          "description": "Your user ID for team collaboration (optional)"
        },
        "smartCopilot.user.teamId": {
          "type": "string",
          "default": "",
          "description": "Your team ID for collaboration features (optional)"
        },
        "smartCopilot.user.personalAccessToken": {
          "type": "string",
          "default": "",
          "description": "Personal access token for enhanced features (optional)"
        },
        "smartCopilot.features.promptSearch": {
          "type": "boolean",
          "default": true,
          "description": "Enable smart prompt search feature"
        },
        "smartCopilot.features.teamEvents": {
          "type": "boolean",
          "default": true,
          "description": "Enable team events monitoring"
        },
        "smartCopilot.cache.syncInterval": {
          "type": "number",
          "default": 24,
          "description": "Cache sync interval in hours"
        },
        "smartCopilot.cache.maxAge": {
          "type": "number",
          "default": 24,
          "description": "Maximum cache age in hours before auto-update"
        }
      }
    },
    "commands": [
      {
        "command": "smartCopilot.openPanel",
        "title": "Smart Copilot Assistant: Open Panel"
      },
      {
        "command": "smartCopilot.syncCache",
        "title": "Sync Team Events Cache"
      },
      {
        "command": "smartCopilot.clearCache",
        "title": "Clear Local Cache"
      },
      {
        "command": "smartCopilot.showConfiguration",
        "title": "Show Configuration Status"
      },
      {
        "command": "smartCopilot.openSettings",
        "title": "Open Smart Copilot Settings"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "smartCopilot.openPanel",
          "when": "true"
        },
        {
          "command": "smartCopilot.syncCache",
          "when": "true"
        },
        {
          "command": "smartCopilot.clearCache",
          "when": "true"
        },
        {
          "command": "smartCopilot.showConfiguration",
          "when": "true"
        },
        {
          "command": "smartCopilot.openSettings",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "16.x",
    "@types/pg": "^8.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "pg": "^8.11.0"
  }
}