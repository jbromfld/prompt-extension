{
  "name": "smart-copilot-assistant",
  "publisher": "local",
  "displayName": "Smart Copilot Assistant",
  "description": "Prompt library and feedback assistant for GitHub Copilot",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Smart Copilot Assistant",
      "properties": {
        "smartCopilot.user.id": {
          "type": "string",
          "default": "",
          "description": "Optional user ID for prompt usage and feedback attribution"
        },
        "smartCopilot.promptService.url": {
          "type": "string",
          "default": "http://127.0.0.1:8090",
          "description": "Base URL for prompt-service"
        }
      }
    },
    "commands": [
      {
        "command": "smartCopilot.openPanel",
        "title": "Smart Copilot Assistant: Open Panel"
      },
      {
        "command": "smartCopilot.showConfiguration",
        "title": "Show Configuration Status"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "smartCopilot.openPanel",
          "when": "true"
        },
        {
          "command": "smartCopilot.showConfiguration",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository --skip-license",
    "vsix:build": "npm run compile && npm run package",
    "install:service": "./install-service.sh",
    "install:local": "./install.sh"
  },
  "devDependencies": {
    "@vscode/vsce": "2.24.0",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {},
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "undici": "5.28.5"
  }
}